---
import Layout from '@/layouts/Layout.astro';
import { getProducts, getCategories, formatPrice } from '@/lib/woocommerce';
import { url } from '@/lib/utils';

const [products, categories] = await Promise.all([
  getProducts({ featured: 1, per_page: 8 }),
  getCategories({ parent: 0, hide_empty: 1 }),
]);

const mainCategories = categories.filter(c => c.slug !== 'uncategorized' && c.count > 0).slice(0, 6);
---

<Layout title="Home">
  <!-- Hero -->
  <section class="relative bg-earth text-white overflow-hidden min-h-[70vh] flex items-center">
    <div class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-36">
      <p class="text-wheat text-sm font-semibold uppercase tracking-widest mb-4">Val d'Orcia · Toscana</p>
      <h1 class="font-heading text-5xl md:text-7xl font-bold leading-tight mb-6">
        Pasta artigianale<br />come una volta
      </h1>
      <p class="text-white/80 text-lg max-w-xl mb-10 leading-relaxed">
        Grano 100% italiano, trafilata al bronzo, essiccata lentamente.
        La tradizione della pasta toscana direttamente a casa tua.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href={url('/prodotti')} class="bg-brand hover:bg-brand-dark text-white px-8 py-4 rounded-xl font-semibold transition-colors">
          Scopri i prodotti
        </a>
        <a href={url('/chi-siamo')} class="border border-white/30 hover:border-white text-white px-8 py-4 rounded-xl font-semibold transition-colors">
          La nostra storia
        </a>
      </div>
    </div>
  </section>

  <!-- Valori brand -->
  <section class="bg-wheat py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      {[
        { icon: '🌾', label: 'Grano 100% italiano' },
        { icon: '🏺', label: 'Trafilata al bronzo' },
        { icon: '🤲', label: 'Lavorazione artigianale' },
        { icon: '🚚', label: 'Spedizione in 24h' },
      ].map(({ icon, label }) => (
        <div class="flex flex-col items-center gap-2">
          <span class="text-3xl">{icon}</span>
          <span class="text-sm font-semibold text-earth">{label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Categorie -->
  {mainCategories.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <h2 class="font-heading text-4xl font-bold text-center mb-12">Le nostre linee</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
        {mainCategories.map((cat) => (
          <a
            href={url(`/categorie/${cat.slug}`)}
            class="group relative rounded-2xl overflow-hidden bg-wheat aspect-[4/3] flex items-end hover:shadow-lg transition-shadow"
          >
            {cat.image && (
              <img
                src={cat.image.src}
                alt={cat.image.alt || cat.name}
                class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
            )}
            <div class="relative z-10 w-full bg-gradient-to-t from-black/70 to-transparent p-4">
              <h3 class="font-heading text-white font-bold text-lg">{cat.name}</h3>
              <p class="text-white/70 text-sm">{cat.count} prodotti</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Prodotti in evidenza -->
  {products.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="flex items-center justify-between mb-12">
        <h2 class="font-heading text-4xl font-bold">In evidenza</h2>
        <a href={url('/prodotti')} class="text-brand font-semibold hover:underline text-sm">Vedi tutti →</a>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {products.map((product) => (
          <a
            href={url(`/prodotti/${product.slug}`)}
            class="group bg-white rounded-card overflow-hidden shadow-sm hover:shadow-md transition-shadow"
          >
            <div class="aspect-square overflow-hidden bg-wheat">
              {product.images[0] ? (
                <img
                  src={product.images[0].src}
                  alt={product.images[0].alt || product.name}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center text-4xl">🍝</div>
              )}
            </div>
            <div class="p-4">
              {product.on_sale && (
                <span class="inline-block bg-brand text-white text-xs font-bold px-2 py-0.5 rounded mb-2">OFFERTA</span>
              )}
              <h3 class="font-semibold text-sm leading-tight mb-2 group-hover:text-brand transition-colors">
                {product.name}
              </h3>
              <div class="flex items-center gap-2">
                <span class="text-brand font-bold">{formatPrice(product.price)}</span>
                {product.on_sale && product.regular_price && (
                  <span class="text-gray-500 line-through text-xs">{formatPrice(product.regular_price)}</span>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- CTA finale -->
  <section class="bg-brand text-white py-20 text-center">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="font-heading text-4xl font-bold mb-4">Pacchi risparmio</h2>
      <p class="text-white/80 mb-8 text-lg">
        Risparmia acquistando le nostre confezioni da 8 pacchi. Stessa qualità, prezzo conveniente.
      </p>
      <a href={url('/prodotti')} class="bg-white text-brand px-8 py-4 rounded-xl font-bold hover:bg-wheat transition-colors">
        Scopri i pacchi risparmio
      </a>
    </div>
  </section>
</Layout>
