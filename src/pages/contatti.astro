---
import Layout from '@/layouts/Layout.astro';
import { getPageBySlug, stripHtml } from '@/lib/wordpress';
import { url } from '@/lib/utils';

const page = await getPageBySlug('contatti-pasta-panarese');
const title = page ? stripHtml(page.title.rendered) : 'Contatti';
---

<Layout title={title}>
  <!-- Hero -->
  <section class="bg-brown py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-white/60 mb-4 flex items-center gap-2">
        <a href={url('/')} class="hover:text-amber transition-colors">Home</a>
        <span>/</span>
        <span class="text-amber">Contatti</span>
      </nav>
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-amber">{title}</h1>
    </div>
  </section>

  <!-- Content -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    {page ? (
      <div class="prose prose-lg max-w-none text-muted leading-relaxed" set:html={page.content.rendered} />
    ) : (
      <p class="text-center text-muted py-20">Contenuto non disponibile.</p>
    )}

    <!-- Contact Info -->
    <div class="mt-12 border-t border-brown/10 pt-12">
      <div class="grid md:grid-cols-2 gap-8">
        <div>
          <h2 class="font-heading text-2xl font-bold text-brown-dark mb-4">Indirizzo</h2>
          <p class="text-muted leading-relaxed">
            Via del Colombaio snc<br />
            Castiglione d'Orcia, SI
          </p>
        </div>
        <div>
          <h2 class="font-heading text-2xl font-bold text-brown-dark mb-4">Email</h2>
          <a href="mailto:info@pastapanarese.it" class="text-amber hover:text-brown transition-colors font-medium">
            info@pastapanarese.it
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
