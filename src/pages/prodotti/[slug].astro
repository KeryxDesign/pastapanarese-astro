---
import Layout from '@/layouts/Layout.astro';
import { getProducts, getProductById, formatPrice } from '@/lib/woocommerce';
import AddToCart from '@/components/AddToCart';
import { url } from '@/lib/utils';

export async function getStaticPaths() {
  const products = await getProducts({ per_page: 100 });
  return products.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const products = await getProducts({ slug });
const product = products[0];

if (!product) return Astro.redirect(url('/prodotti'));

// Fetch related products
const relatedIds = [...(product.related_ids ?? []), ...(product.cross_sell_ids ?? [])].slice(0, 4);
const related = relatedIds.length > 0
  ? await Promise.all(relatedIds.map(id => getProductById(id).catch(() => null)))
  : [];
const relatedProducts = related.filter(Boolean);

const mainImage = product.images[0];
const galleryImages = product.images.slice(1);

function stripHtml(html: string) {
  return html.replace(/<[^>]*>/g, '').replace(/&amp;/g, '&').replace(/&nbsp;/g, ' ').trim();
}
---

<Layout title={product.name} description={stripHtml(product.short_description || product.description).slice(0, 160)}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Breadcrumb -->
    <nav class="text-sm text-muted mb-8 flex items-center gap-2">
      <a href={url('/')} class="hover:text-amber transition-colors">Home</a>
      <span>/</span>
      <a href={url('/prodotti')} class="hover:text-amber transition-colors">Prodotti</a>
      <span>/</span>
      <span class="text-earth font-medium">{product.name}</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-16">
      <!-- Immagini -->
      <div class="space-y-4">
        <div class="aspect-square rounded-2xl overflow-hidden bg-cream">
          {mainImage ? (
            <img
              id="main-image"
              src={mainImage.src}
              alt={mainImage.alt || product.name}
              class="w-full h-full object-cover"
            />
          ) : (
            <div class="w-full h-full flex items-center justify-center text-muted text-7xl">
              Pasta
            </div>
          )}
        </div>
        {galleryImages.length > 0 && (
          <div class="flex gap-3 overflow-x-auto pb-2">
            {product.images.map((img, i) => (
              <button
                onclick={`document.getElementById('main-image').src='${img.src}'`}
                class="flex-shrink-0 w-20 h-20 rounded-lg overflow-hidden border-2 border-transparent hover:border-amber transition-colors"
              >
                <img src={img.src} alt={img.alt || ''} class="w-full h-full object-cover" />
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- Info prodotto -->
      <div>
        <!-- Categorie badge -->
        <div class="flex flex-wrap gap-2 mb-4">
          {product.categories.map((cat) => (
            <a
              href={url(`/categorie/${cat.slug}`)}
              class="text-xs font-semibold text-brown bg-amber/20 px-3 py-1 rounded-full hover:bg-amber/30 transition-colors"
            >
              {cat.name}
            </a>
          ))}
        </div>

        <h1 class="font-heading text-4xl font-bold text-earth mb-4">{product.name}</h1>

        <!-- Prezzo -->
        <div class="flex items-center gap-3 mb-6">
          <span class="text-3xl font-bold text-amber">{formatPrice(product.price)}</span>
          {product.on_sale && product.regular_price && (
            <span class="text-xl text-gray-500 line-through">{formatPrice(product.regular_price)}</span>
          )}
          {product.on_sale && (
            <span class="bg-amber text-brown text-sm font-bold px-3 py-1 rounded-full">OFFERTA</span>
          )}
        </div>

        <!-- Descrizione breve -->
        {product.short_description && (
          <div class="text-muted leading-relaxed mb-6 prose prose-sm max-w-none"
            set:html={product.short_description}
          />
        )}

        <!-- Attributi (lavorazione, cottura) -->
        {product.attributes.length > 0 && (
          <div class="bg-warm rounded-xl p-4 mb-6 space-y-2">
            {product.attributes.map((attr) => (
              <div class="flex items-start gap-3 text-sm">
                <span class="font-semibold text-earth min-w-[120px]">{attr.name}:</span>
                <span class="text-muted">{attr.options.join(', ')}</span>
              </div>
            ))}
          </div>
        )}

        <!-- Add to cart -->
        <AddToCart
          client:load
          id={product.id}
          name={product.name}
          price={product.price}
          image={mainImage?.src ?? ''}
          slug={product.slug}
        />

        <!-- Peso/dimensioni -->
        {(product.weight || product.dimensions?.length) && (
          <div class="mt-6 text-xs text-muted flex gap-4">
            {product.weight && <span>Peso: {product.weight} kg</span>}
            {product.dimensions?.length && (
              <span>Dim: {product.dimensions.length}x{product.dimensions.width}x{product.dimensions.height} cm</span>
            )}
          </div>
        )}
      </div>
    </div>

    <!-- Descrizione completa -->
    {product.description && (
      <div class="bg-white rounded-2xl p-8 mb-16 shadow-sm">
        <h2 class="font-heading text-2xl font-bold text-earth mb-6">Descrizione</h2>
        <div class="prose prose-lg max-w-none text-muted leading-relaxed"
          set:html={product.description}
        />
      </div>
    )}

    <!-- Prodotti correlati -->
    {relatedProducts.length > 0 && (
      <div>
        <h2 class="font-heading text-3xl font-bold text-earth mb-8">Potrebbe interessarti</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          {relatedProducts.map((rel) => rel && (
            <a
              href={url(`/prodotti/${rel.slug}`)}
              class="group bg-white rounded-card overflow-hidden shadow-sm hover:shadow-md transition-shadow"
            >
              <div class="aspect-square overflow-hidden bg-cream">
                {rel.images[0] ? (
                  <img
                    src={rel.images[0].src}
                    alt={rel.images[0].alt || rel.name}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-muted text-4xl">
                    Pasta
                  </div>
                )}
              </div>
              <div class="p-4">
                <h3 class="font-semibold text-sm text-earth leading-tight mb-2 group-hover:text-amber transition-colors">
                  {rel.name}
                </h3>
                <span class="text-amber font-bold text-sm">{formatPrice(rel.price)}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</Layout>
